<!DOCTYPE html>
<html>
  <head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <style>
      body { margin: 0; padding: 0; background-color: #ffffff; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #111111; }
      .wrapper { max-width: 520px; margin: 40px auto; padding: 0 24px; }
      .logo { margin-bottom: 24px; }
      .logo-name { font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #bc423a; }
      .divider { border: none; border-top: 1px solid #e5e5e5; margin: 20px 0; }
      p { font-size: 15px; line-height: 1.6; margin: 0 0 16px; color: #111111; }
      .btn { display: inline-block; padding: 12px 28px; background-color: #bc423a; color: #ffffff !important; text-decoration: none; font-size: 13px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; border-radius: 6px; }
      .footer { margin-top: 32px; padding-top: 16px; border-top: 1px solid #e5e5e5; font-size: 12px; color: #888888; }
    </style>
  </head>
  <body>
    <div class="wrapper">
      <div class="logo">
        <span class="logo-name">Freedom Podcasting</span>
      </div>
      <hr class="divider" />
      <%= yield %>
      <div class="footer">
        <p style="color:#888888;font-size:12px;">Freedom Podcasting &mdash; Professional podcast management</p>
      </div>
    </div>
  </body>
</html>
